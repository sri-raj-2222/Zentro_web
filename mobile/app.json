{
  "expo": {
    "name": "Zentro",
    "slug": "zentro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/zentro_logo.png",
    "scheme": "zentro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sriraj2222.zentro",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Zentro needs your location to auto-detect your service address."
      }
    },
    "android": {
      "package": "com.sri_raj_2222.zentro",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/zentro_logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Zentro needs your location to auto-detect your service address.",
          "locationWhenInUsePermission": "Zentro needs your location to auto-detect your service address."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Zentro needs access to your photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "eas": {
        "projectId": "b3f47a4b-4ea3-4354-88b1-3cf579dafba0"
      }
    }
  }
}
