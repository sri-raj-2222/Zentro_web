{
  "expo": {
    "name": "Zentro",
    "slug": "zentro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/zentro_logo.png",
    "scheme": "zentro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/zentro_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.sri_raj_2222.zentro"
    },
    "web": {
      "favicon": "./assets/images/zentro_logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "eas": {
        "projectId": "b3f47a4b-4ea3-4354-88b1-3cf579dafba0"
      }
    }
  }
}
